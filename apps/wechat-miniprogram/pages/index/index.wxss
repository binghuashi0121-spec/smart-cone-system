.home-page {
  overflow-x: hidden;
}

.home-page .page-title {
  font-size: 48rpx;
  font-weight: 900;
}

.task-strip {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 18rpx 0 18rpx;
  white-space: nowrap;
  width: 100%;
  overflow: hidden;
}

.mode-pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  height: 52rpx;
  flex-shrink: 0;
  padding: 0 16rpx;
  border: 1rpx solid rgba(255, 122, 0, 0.58);
  border-radius: 10rpx;
  color: #ff9b28;
  font-size: 24rpx;
  font-weight: 700;
  background: rgba(255, 122, 0, 0.1);
}

.moon {
  font-size: 32rpx;
}

.dot-icon {
  width: 16rpx;
  height: 16rpx;
  flex-shrink: 0;
}

.task-stat {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  height: 52rpx;
  font-size: 23rpx;
}

.strong {
  color: #ffffff;
  font-weight: 800;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.green-bg {
  background: #22c55e;
  box-shadow: 0 0 18rpx rgba(34, 197, 94, 0.7);
}

.alert-stat {
  color: #ff3b30;
  font-weight: 700;
}

.task-sep {
  width: 1rpx;
  height: 34rpx;
  background: rgba(255, 255, 255, 0.16);
}

.task-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: auto;
  color: #aab2c0;
  font-size: 22rpx;
  min-width: 0;
}

.map-card {
  position: relative;
  height: 530rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
}

.route-label {
  position: absolute;
  left: 22rpx;
  right: 112rpx;
  top: 20rpx;
  z-index: 5;
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 13rpx;
  color: #d7dce4;
  font-size: 23rpx;
  background: rgba(4, 9, 16, 0.72);
  overflow: hidden;
  white-space: nowrap;
}

.route-label text:last-child {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.locate-btn {
  position: absolute;
  right: 30rpx;
  top: 28rpx;
  z-index: 8;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 10rpx;
  color: #ffffff;
  background: rgba(20, 25, 32, 0.82);
}

.map-card > .locate-btn {
  right: 122rpx;
  top: 33rpx;
  width: 34rpx;
  height: 34rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 8rpx;
  background: rgba(7, 17, 29, 0.76);
  box-shadow: 0 0 10rpx rgba(146, 187, 255, 0.12);
}

.locate-icon,
.locate-btn .ui-icon {
  width: 24rpx;
  height: 24rpx;
}

.map-card > .locate-btn .locate-icon {
  width: 19rpx;
  height: 19rpx;
  opacity: 0.95;
  filter: drop-shadow(0 0 8rpx rgba(255, 255, 255, 0.28));
}

.fake-map {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: 22rpx;
  background:
    linear-gradient(35deg, rgba(255, 255, 255, 0.035) 1rpx, transparent 1rpx) 0 0 / 48rpx 48rpx,
    linear-gradient(125deg, rgba(255, 255, 255, 0.035) 1rpx, transparent 1rpx) 0 0 / 58rpx 58rpx,
    radial-gradient(circle at 70% 35%, rgba(38, 72, 99, 0.2), transparent 34%),
    #07111d;
}

.fake-map::before {
  content: "";
  position: absolute;
  left: -34%;
  top: -20%;
  z-index: 1;
  width: 28%;
  height: 140%;
  transform: rotate(18deg);
  background: linear-gradient(90deg, transparent, rgba(102, 171, 255, 0.16), rgba(255, 255, 255, 0.1), transparent);
  animation: mapSweep 5.6s ease-in-out infinite;
  pointer-events: none;
}

.fake-map::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  border-radius: inherit;
  background: radial-gradient(circle at 50% 52%, rgba(255, 122, 0, 0.12), transparent 34%);
  opacity: 0.75;
  animation: mapGlow 3.2s ease-in-out infinite;
  pointer-events: none;
}

.fake-map.scene-night {
  background:
    linear-gradient(35deg, rgba(104, 170, 255, 0.045) 1rpx, transparent 1rpx) 0 0 / 48rpx 48rpx,
    linear-gradient(125deg, rgba(104, 170, 255, 0.04) 1rpx, transparent 1rpx) 0 0 / 58rpx 58rpx,
    radial-gradient(circle at 68% 32%, rgba(42, 103, 169, 0.34), transparent 36%),
    linear-gradient(180deg, rgba(3, 10, 25, 0.94), rgba(3, 15, 31, 0.98));
}

.fake-map.scene-night::before {
  background: linear-gradient(90deg, transparent, rgba(108, 179, 255, 0.24), rgba(255, 255, 255, 0.15), transparent);
  animation: mapSweep 4.8s ease-in-out infinite;
}

.fake-map.scene-night::after {
  background:
    radial-gradient(circle at 50% 52%, rgba(255, 179, 71, 0.16), transparent 34%),
    linear-gradient(180deg, rgba(0, 14, 40, 0.24), rgba(0, 0, 0, 0.28));
  animation: nightMapBreath 3s ease-in-out infinite;
}

.fake-map.scene-night .road {
  box-shadow: 0 0 42rpx rgba(107, 172, 255, 0.16), inset 0 0 22rpx rgba(107, 172, 255, 0.06);
}

.fake-map.scene-night .cone-body {
  filter: drop-shadow(0 0 18rpx rgba(255, 255, 255, 0.94)) drop-shadow(0 0 18rpx rgba(255, 138, 31, 0.72));
}

.fake-map.scene-fog {
  background:
    linear-gradient(35deg, rgba(210, 229, 245, 0.05) 1rpx, transparent 1rpx) 0 0 / 48rpx 48rpx,
    linear-gradient(125deg, rgba(210, 229, 245, 0.045) 1rpx, transparent 1rpx) 0 0 / 58rpx 58rpx,
    radial-gradient(circle at 26% 38%, rgba(184, 214, 232, 0.22), transparent 34%),
    radial-gradient(circle at 78% 28%, rgba(82, 147, 196, 0.3), transparent 42%),
    linear-gradient(180deg, #0d1d28, #08131d 60%, #050d15);
  filter: saturate(0.78);
}

.fake-map.scene-fog::before {
  left: -22%;
  top: -18%;
  z-index: 4;
  width: 180%;
  height: 180%;
  transform: rotate(0);
  background:
    repeating-linear-gradient(112deg, rgba(165, 215, 255, 0.26) 0, rgba(165, 215, 255, 0.26) 2rpx, transparent 2rpx, transparent 26rpx),
    repeating-linear-gradient(112deg, transparent 0, transparent 14rpx, rgba(255, 255, 255, 0.12) 14rpx, rgba(255, 255, 255, 0.12) 16rpx, transparent 16rpx, transparent 44rpx),
    linear-gradient(90deg, rgba(192, 214, 226, 0.08), rgba(192, 214, 226, 0.2), rgba(192, 214, 226, 0.06));
  animation: rainFogMove 0.95s linear infinite;
}

.fake-map.scene-fog::after {
  z-index: 3;
  background:
    linear-gradient(90deg, rgba(211, 228, 236, 0.05), rgba(211, 228, 236, 0.22), rgba(211, 228, 236, 0.06)),
    radial-gradient(ellipse at 24% 36%, rgba(226, 239, 244, 0.32), transparent 36%),
    radial-gradient(ellipse at 68% 62%, rgba(202, 224, 236, 0.28), transparent 42%),
    radial-gradient(ellipse at 48% 50%, rgba(180, 210, 228, 0.2), transparent 54%),
    linear-gradient(180deg, rgba(124, 156, 174, 0.18), rgba(124, 156, 174, 0.38));
  opacity: 0.96;
  animation: fogDrift 4.8s ease-in-out infinite;
}

.fake-map.scene-fog .road {
  background:
    linear-gradient(180deg, rgba(92, 113, 126, 0.86), rgba(36, 51, 63, 0.94)),
    repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.08) 0, rgba(255, 255, 255, 0.08) 1rpx, transparent 1rpx, transparent 18rpx);
  filter: saturate(0.72) brightness(1.1);
  box-shadow: 0 0 40rpx rgba(180, 210, 232, 0.18), inset 0 0 30rpx rgba(190, 220, 238, 0.1);
}

.fake-map.scene-fog .road::before {
  content: "";
  position: absolute;
  left: 6%;
  right: 6%;
  top: 14rpx;
  height: 28rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, transparent, rgba(210, 235, 255, 0.24), transparent);
  filter: blur(2rpx);
  opacity: 0.8;
  animation: wetReflection 3s ease-in-out infinite;
}

.fake-map.scene-fog .road::after {
  background: linear-gradient(90deg, transparent, rgba(225, 242, 255, 0.24), rgba(255, 255, 255, 0.2), transparent);
  animation: wetRoadSweep 2.8s linear infinite;
}

.fake-map.scene-fog .water {
  background: rgba(88, 157, 196, 0.3);
  box-shadow: inset 0 0 28rpx rgba(210, 235, 255, 0.12);
}

.fake-map.scene-fog .work-zone {
  border-color: rgba(105, 169, 255, 0.92);
  color: #c8ecff;
  background:
    repeating-linear-gradient(135deg, rgba(105, 169, 255, 0.18) 0, rgba(105, 169, 255, 0.18) 5rpx, rgba(250, 204, 21, 0.14) 5rpx, rgba(250, 204, 21, 0.14) 10rpx, transparent 10rpx, transparent 17rpx),
    rgba(105, 169, 255, 0.1);
  box-shadow: 0 0 46rpx rgba(105, 169, 255, 0.34), inset 0 0 18rpx rgba(250, 204, 21, 0.14);
  animation: fogZoneSignal 2s ease-in-out infinite;
}

.fake-map.scene-fog .cone-body {
  filter: drop-shadow(0 0 16rpx rgba(155, 214, 255, 0.88)) drop-shadow(0 0 12rpx rgba(250, 204, 21, 0.68));
}

.fake-map.scene-fog .direction {
  color: rgba(225, 239, 248, 0.58);
}

.fake-map.scene-emergency {
  background:
    linear-gradient(35deg, rgba(255, 87, 77, 0.055) 1rpx, transparent 1rpx) 0 0 / 48rpx 48rpx,
    linear-gradient(125deg, rgba(255, 87, 77, 0.045) 1rpx, transparent 1rpx) 0 0 / 58rpx 58rpx,
    radial-gradient(circle at 66% 34%, rgba(255, 59, 48, 0.26), transparent 36%),
    #11070a;
  box-shadow: inset 0 0 52rpx rgba(255, 59, 48, 0.2);
}

.fake-map.scene-emergency::before {
  left: -28%;
  top: -20%;
  z-index: 4;
  width: 24%;
  height: 150%;
  transform: rotate(18deg);
  background: linear-gradient(90deg, transparent, rgba(255, 59, 48, 0.34), rgba(255, 244, 238, 0.22), transparent);
  animation: mapSweep 2.1s ease-in-out infinite;
}

.fake-map.scene-emergency::after {
  z-index: 3;
  border: 2rpx solid rgba(255, 59, 48, 0.58);
  background:
    radial-gradient(circle at 50% 50%, rgba(255, 59, 48, 0.22), transparent 36%),
    linear-gradient(180deg, rgba(255, 59, 48, 0.09), rgba(40, 0, 0, 0.18));
  animation: emergencyMapFlash 1.1s ease-in-out infinite;
}

.fake-map.scene-emergency .road,
.fake-map.scene-emergency .emergency-lane {
  box-shadow: 0 0 38rpx rgba(255, 59, 48, 0.28), inset 0 0 18rpx rgba(255, 59, 48, 0.12);
}

.fake-map.scene-emergency .work-zone {
  border-color: rgba(255, 59, 48, 0.98);
  color: #ff8a80;
  background:
    repeating-linear-gradient(135deg, rgba(255, 59, 48, 0.22) 0, rgba(255, 59, 48, 0.22) 5rpx, transparent 5rpx, transparent 14rpx),
    rgba(255, 59, 48, 0.12);
  box-shadow: 0 0 48rpx rgba(255, 59, 48, 0.44);
  animation: emergencyZonePulse 1.2s ease-in-out infinite;
}

.fake-map.scene-emergency .cone::before {
  opacity: 1;
  background: radial-gradient(circle, rgba(255, 59, 48, 0.68) 0%, rgba(255, 59, 48, 0.22) 52%, transparent 76%);
  box-shadow: 0 0 22rpx rgba(255, 59, 48, 0.86);
}

.fake-map.scene-emergency .cone::after {
  content: "";
  position: absolute;
  left: -22rpx;
  top: 6rpx;
  width: 74rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 59, 48, 0.82);
  animation: pulse 0.9s infinite;
}

.fake-map.scene-emergency .cone-body {
  filter: drop-shadow(0 0 22rpx rgba(255, 59, 48, 1));
}

.water {
  position: absolute;
  width: 50rpx;
  height: 460rpx;
  border-radius: 60rpx;
  background: rgba(0, 72, 123, 0.28);
  transform: rotate(28deg);
}

.water.one {
  left: 90rpx;
  top: -40rpx;
}

.water.two {
  right: 210rpx;
  top: -90rpx;
}

.road {
  position: absolute;
  left: -60rpx;
  right: -60rpx;
  top: 190rpx;
  height: 152rpx;
  transform: rotate(15deg);
  border-top: 4rpx solid rgba(255, 255, 255, 0.18);
  border-bottom: 4rpx solid rgba(255, 255, 255, 0.18);
  background: linear-gradient(180deg, rgba(34, 41, 50, 0.82), rgba(19, 27, 37, 0.88));
  box-shadow: 0 0 34rpx rgba(255, 255, 255, 0.05);
}

.road::after {
  content: "";
  position: absolute;
  left: -28%;
  top: 0;
  width: 24%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.16), transparent);
  animation: roadScan 4.8s linear infinite;
}

.lane {
  position: absolute;
  left: 0;
  right: 0;
  height: 0;
  border-top: 3rpx dashed rgba(255, 255, 255, 0.26);
}

.lane-one {
  top: 50rpx;
}

.lane-two {
  top: 100rpx;
}

.direction {
  position: absolute;
  color: rgba(255, 255, 255, 0.7);
  font-size: 26rpx;
}

.direction.left {
  left: 70rpx;
  top: 20rpx;
}

.direction.right {
  right: 80rpx;
  bottom: 18rpx;
}

.work-zone {
  position: absolute;
  left: 220rpx;
  top: 207rpx;
  width: 306rpx;
  height: 124rpx;
  transform: rotate(15deg) skewX(-18deg);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 122, 0, 0.85);
  color: #ff9b28;
  font-size: 25rpx;
  font-weight: 700;
  gap: 8rpx;
  background:
    repeating-linear-gradient(135deg, rgba(255, 122, 0, 0.17) 0, rgba(255, 122, 0, 0.17) 5rpx, transparent 5rpx, transparent 14rpx),
    rgba(255, 122, 0, 0.1);
  box-shadow: 0 0 30rpx rgba(255, 122, 0, 0.28);
  animation: workZoneGlow 2.8s ease-in-out infinite;
}

.work-zone text {
  transform: skewX(18deg);
}

.cone {
  position: absolute;
  z-index: 6;
  width: 30rpx;
  height: 36rpx;
  margin-left: -15rpx;
  margin-top: -18rpx;
  overflow: visible;
  background: transparent !important;
}

.cone::before {
  content: "";
  position: absolute;
  left: -12rpx;
  top: 6rpx;
  z-index: 1;
  width: 54rpx;
  height: 38rpx;
  border-radius: 50%;
  opacity: 0;
}

.cone-body {
  position: absolute;
  left: -4rpx;
  top: -4rpx;
  z-index: 2;
  width: 38rpx;
  height: 44rpx;
  filter: drop-shadow(0 0 12rpx rgba(255, 255, 255, 0.72));
}

.cone.map-low::before {
  opacity: 1;
  background: radial-gradient(circle, rgba(250, 204, 21, 0.68) 0%, rgba(250, 204, 21, 0.2) 52%, transparent 74%);
  box-shadow: 0 0 18rpx rgba(250, 204, 21, 0.75);
}

.cone.map-shifted::before {
  opacity: 1;
  background: radial-gradient(circle, rgba(255, 122, 0, 0.9) 0%, rgba(255, 122, 0, 0.34) 52%, transparent 78%);
  box-shadow: 0 0 30rpx rgba(255, 122, 0, 0.95);
}

.cone.map-tilted::before {
  opacity: 1;
  background: radial-gradient(circle, rgba(255, 59, 48, 0.72) 0%, rgba(255, 59, 48, 0.24) 52%, transparent 76%);
  box-shadow: 0 0 22rpx rgba(255, 59, 48, 0.9);
}

.cone.map-low .cone-body {
  filter: drop-shadow(0 0 18rpx rgba(250, 204, 21, 0.98));
}

.cone.map-shifted .cone-body {
  filter: drop-shadow(0 0 20rpx rgba(255, 122, 0, 0.98));
}

.cone.map-tilted .cone-body {
  filter: drop-shadow(0 0 22rpx rgba(255, 59, 48, 1));
}

.cone.map-shifted::after,
.cone.map-tilted::after,
.cone.focus::after {
  content: "";
  position: absolute;
  left: -22rpx;
  top: 6rpx;
  width: 74rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 59, 48, 0.72);
  animation: pulse 1.4s infinite;
}

.cone.map-shifted::after {
  border-color: rgba(255, 122, 0, 0.72);
}

.cone.map-offline .cone-body {
  filter: grayscale(1);
  opacity: 0.72;
}

@keyframes pulse {
  0% {
    opacity: 0.9;
    transform: scale(0.78);
  }
  100% {
    opacity: 0;
    transform: scale(1.35);
  }
}

@keyframes mapSweep {
  0% {
    left: -34%;
    opacity: 0;
  }
  18% {
    opacity: 1;
  }
  58% {
    left: 112%;
    opacity: 0.75;
  }
  100% {
    left: 112%;
    opacity: 0;
  }
}

@keyframes mapGlow {
  0%,
  100% {
    opacity: 0.48;
  }
  50% {
    opacity: 0.9;
  }
}

@keyframes roadScan {
  0% {
    left: -28%;
    opacity: 0;
  }
  16% {
    opacity: 1;
  }
  100% {
    left: 112%;
    opacity: 0;
  }
}

@keyframes workZoneGlow {
  0%,
  100% {
    box-shadow: 0 0 24rpx rgba(255, 122, 0, 0.22), inset 0 0 8rpx rgba(255, 122, 0, 0.08);
  }
  50% {
    box-shadow: 0 0 42rpx rgba(255, 122, 0, 0.42), inset 0 0 18rpx rgba(255, 122, 0, 0.16);
  }
}

@keyframes nightMapBreath {
  0%,
  100% {
    opacity: 0.58;
  }
  50% {
    opacity: 0.92;
  }
}

@keyframes rainFogMove {
  0% {
    transform: translate3d(0, -7%, 0);
    opacity: 0.5;
  }
  100% {
    transform: translate3d(-11%, 8%, 0);
    opacity: 0.9;
  }
}

@keyframes fogDrift {
  0%,
  100% {
    transform: translateX(-2%);
    opacity: 0.76;
  }
  50% {
    transform: translateX(3%);
    opacity: 0.96;
  }
}

@keyframes wetReflection {
  0%,
  100% {
    transform: translateX(-8%);
    opacity: 0.46;
  }
  50% {
    transform: translateX(10%);
    opacity: 0.88;
  }
}

@keyframes wetRoadSweep {
  0% {
    left: -30%;
    opacity: 0;
  }
  20% {
    opacity: 0.95;
  }
  100% {
    left: 112%;
    opacity: 0;
  }
}

@keyframes fogZoneSignal {
  0%,
  100% {
    box-shadow: 0 0 32rpx rgba(105, 169, 255, 0.22), inset 0 0 12rpx rgba(250, 204, 21, 0.1);
  }
  50% {
    box-shadow: 0 0 58rpx rgba(105, 169, 255, 0.48), 0 0 22rpx rgba(250, 204, 21, 0.18), inset 0 0 22rpx rgba(250, 204, 21, 0.18);
  }
}

@keyframes emergencyMapFlash {
  0%,
  100% {
    opacity: 0.48;
    box-shadow: inset 0 0 24rpx rgba(255, 59, 48, 0.16);
  }
  50% {
    opacity: 0.95;
    box-shadow: inset 0 0 58rpx rgba(255, 59, 48, 0.38);
  }
}

@keyframes emergencyZonePulse {
  0%,
  100% {
    box-shadow: 0 0 28rpx rgba(255, 59, 48, 0.28), inset 0 0 8rpx rgba(255, 59, 48, 0.08);
  }
  50% {
    box-shadow: 0 0 56rpx rgba(255, 59, 48, 0.58), inset 0 0 18rpx rgba(255, 59, 48, 0.16);
  }
}

.expand-map {
  position: absolute;
  left: 50%;
  bottom: 20rpx;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  width: 300rpx;
  height: 58rpx;
  padding: 0 36rpx;
  transform: translateX(-50%);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 700;
  background: rgba(25, 31, 40, 0.82);
}

.expand-map .ui-icon-sm {
  position: absolute;
  left: 38rpx;
}

.expand-map text {
  display: block;
  width: 100%;
  text-align: center;
}

.emergency-panel {
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.emergency-main {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 360rpx;
  max-width: 100%;
  min-height: 118rpx;
  margin: 0 auto;
  padding: 0 18rpx;
  border: 1rpx solid rgba(255, 59, 48, 0.86);
  border-radius: 18rpx;
  background:
    linear-gradient(90deg, rgba(255, 59, 48, 0.5), rgba(255, 59, 48, 0.18)),
    repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.05) 0, rgba(255, 255, 255, 0.05) 1rpx, transparent 1rpx, transparent 18rpx);
  box-shadow: inset 0 0 32rpx rgba(255, 59, 48, 0.34), 0 0 26rpx rgba(255, 59, 48, 0.28);
  overflow: hidden;
  animation: emergencyPulse 2.6s ease-in-out infinite;
}

.emergency-main::before {
  content: "";
  position: absolute;
  left: -70%;
  top: 0;
  z-index: 1;
  width: 48%;
  height: 100%;
  transform: skewX(-20deg);
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.22), transparent);
  animation: emergencySweep 3.2s ease-in-out infinite;
}

.emergency-main::after {
  content: "";
  position: absolute;
  inset: 8rpx;
