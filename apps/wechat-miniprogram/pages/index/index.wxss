  font-size: 25rpx;
}

.alert-actions {
  flex-wrap: wrap;
}

.alert-actions button {
  flex: 0 0 calc((100% - 14rpx) / 2);
}

.device-detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 16rpx;
}

.device-sheet {
  top: 50%;
  bottom: auto;
  left: 18rpx;
  right: 18rpx;
  max-height: 66vh;
  padding-top: 18rpx;
  transform: translateY(-56%);
  overflow-y: auto;
}

.device-sheet.device-danger {
  border-color: rgba(255, 59, 48, 0.56);
  box-shadow: 0 -18rpx 64rpx rgba(0, 0, 0, 0.56), 0 0 38rpx rgba(255, 59, 48, 0.18), inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

.device-sheet.device-warning {
  border-color: rgba(250, 204, 21, 0.58);
  box-shadow: 0 -18rpx 64rpx rgba(0, 0, 0, 0.56), 0 0 38rpx rgba(250, 204, 21, 0.18), inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

.device-title {
  min-width: 0;
  margin-bottom: 0;
  padding-right: 82rpx;
  color: #ffffff;
}

.device-title > text:nth-child(2) {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.device-status-chip {
  flex-shrink: 0;
  padding: 5rpx 14rpx;
  border: 1rpx solid rgba(34, 197, 94, 0.42);
  border-radius: 999rpx;
  color: #22c55e;
  font-size: 20rpx;
  font-weight: 800;
  background: rgba(34, 197, 94, 0.12);
}

.device-danger .device-title,
.device-danger .device-status-chip {
  color: #ff6b5f;
}

.device-danger .device-status-chip {
  border-color: rgba(255, 59, 48, 0.62);
  background: rgba(255, 59, 48, 0.16);
  box-shadow: 0 0 18rpx rgba(255, 59, 48, 0.18);
}

.device-warning .device-title,
.device-warning .device-status-chip {
  color: #facc15;
}

.device-warning .device-status-chip {
  border-color: rgba(250, 204, 21, 0.62);
  background: rgba(250, 204, 21, 0.16);
  box-shadow: 0 0 18rpx rgba(250, 204, 21, 0.18);
}

.device-shifted .device-title,
.device-shifted .device-status-chip {
  color: #ff9b28;
}

.device-shifted .device-status-chip {
  border-color: rgba(255, 122, 0, 0.62);
  background: rgba(255, 122, 0, 0.16);
  box-shadow: 0 0 18rpx rgba(255, 122, 0, 0.18);
}

.device-close {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 48rpx;
  min-width: 0;
  max-width: 48rpx;
  width: 48rpx;
  height: 48rpx;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  border-color: rgba(255, 255, 255, 0.16);
  border-radius: 10rpx;
  background: rgba(7, 17, 29, 0.88);
  line-height: 1;
  box-shadow: 0 0 14rpx rgba(146, 187, 255, 0.16), inset 0 0 10rpx rgba(255, 255, 255, 0.04);
}

.device-close::after {
  border: 0;
}

.device-close .ui-icon {
  width: 22rpx;
  height: 22rpx;
}

.device-field {
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  color: #dce3ec;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.04);
}

.device-danger .device-status-field,
.device-danger .device-posture-field {
  border-color: rgba(255, 59, 48, 0.44);
  color: #ff8a80;
  background: rgba(255, 59, 48, 0.12);
  box-shadow: inset 0 0 18rpx rgba(255, 59, 48, 0.08);
}

.device-warning .device-status-field,
.device-warning .device-battery-field {
  border-color: rgba(250, 204, 21, 0.46);
  color: #ffe06a;
  background: rgba(250, 204, 21, 0.12);
  box-shadow: inset 0 0 18rpx rgba(250, 204, 21, 0.08);
}

.device-shifted .device-status-field,
.device-shifted .device-posture-field {
  border-color: rgba(255, 122, 0, 0.46);
  color: #ffbd73;
  background: rgba(255, 122, 0, 0.12);
  box-shadow: inset 0 0 18rpx rgba(255, 122, 0, 0.08);
}

.device-offline .device-status-field {
  border-color: rgba(154, 162, 174, 0.46);
  color: #c9d0da;
  background: rgba(154, 162, 174, 0.1);
}

.device-actions {
  flex-wrap: wrap;
}

.device-actions button {
  flex: 0 0 calc((100% - 14rpx) / 2);
}
