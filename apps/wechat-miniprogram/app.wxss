page {
  min-height: 100vh;
  width: 100%;
  overflow-x: hidden;
  color: #ffffff;
  background:
    radial-gradient(circle at 20% 0%, rgba(255, 122, 0, 0.12), transparent 28%),
    radial-gradient(circle at 90% 15%, rgba(40, 132, 255, 0.12), transparent 24%),
    linear-gradient(160deg, #020712 0%, #07111d 46%, #050b14 100%);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
scroll-view {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1.2;
  color: inherit;
  background: transparent;
  border: 0;
  border-radius: 0;
}

button::after {
  border: 0;
}

.app-page {
  width: 100%;
  min-height: 100vh;
  padding: 58rpx 22rpx 190rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  width: 100%;
  min-width: 0;
}

.title-row {
  display: flex;
  align-items: center;
  min-width: 0;
}

.cone-logo {
  width: 56rpx;
  height: 64rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.page-title {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  white-space: nowrap;
  line-height: 1.15;
}

.page-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #aab2c0;
  font-size: 25rpx;
  white-space: nowrap;
}

.capsule {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 15rpx 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 52rpx;
  color: #f5f7fb;
  font-size: 28rpx;
  background: rgba(6, 11, 19, 0.55);
}

.capsule-line {
  width: 1rpx;
  height: 34rpx;
  background: rgba(255, 255, 255, 0.18);
}

.panel {
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 22rpx;
  background: linear-gradient(145deg, rgba(16, 31, 46, 0.92), rgba(7, 17, 29, 0.9));
  box-shadow: 0 18rpx 46rpx rgba(0, 0, 0, 0.32), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.soft-panel {
  border: 1rpx solid rgba(255, 255, 255, 0.09);
  border-radius: 18rpx;
  background: rgba(12, 25, 39, 0.74);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.muted {
  color: #aab2c0;
}

.green {
  color: #22c55e;
}

.orange {
  color: #ff7a00;
}

.red {
  color: #ff3b30;
}

.yellow {
  color: #facc15;
}

.divider {
  width: 1rpx;
  height: 42rpx;
  background: rgba(255, 255, 255, 0.13);
}

.custom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  justify-content: space-around;
  padding: 14rpx 12rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(5, 12, 22, 0.96);
  box-shadow: 0 -16rpx 34rpx rgba(0, 0, 0, 0.34);
}

.nav-item {
  position: relative;
  width: 30%;
  min-height: 82rpx;
  color: #8f98a6;
  font-size: 24rpx;
}

.nav-item.active {
  color: #ff7a00;
}

.nav-item.active::before {
  content: "";
  position: absolute;
  top: -15rpx;
  left: 50%;
  width: 70rpx;
  height: 6rpx;
  margin-left: -35rpx;
  border-radius: 999rpx;
  background: #ff7a00;
  box-shadow: 0 0 16rpx rgba(255, 122, 0, 0.85);
}

.nav-icon {
  display: block;
  margin-bottom: 6rpx;
  font-size: 38rpx;
}

.nav-icon-img {
  display: block;
  width: 42rpx;
  height: 42rpx;
  margin: 0 auto 6rpx;
}

.ui-icon {
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
}

.ui-icon-sm {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
}

.ui-icon-lg {
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
}

.nav-label {
  display: block;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 54rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 12rpx;
  color: #c4cbd6;
  font-size: 24rpx;
  background: rgba(11, 22, 34, 0.76);
  gap: 8rpx;
}

.tag.active {
  color: #ff8a1f;
  border-color: rgba(255, 122, 0, 0.88);
  background: linear-gradient(135deg, rgba(255, 122, 0, 0.26), rgba(255, 122, 0, 0.06));
  box-shadow: 0 0 22rpx rgba(255, 122, 0, 0.15);
}

.primary-btn,
.danger-btn,
.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  gap: 10rpx;
}

.primary-btn {
  border: 1rpx solid rgba(255, 138, 31, 0.82);
  background: linear-gradient(180deg, #ff8a1f, #d95e00);
  box-shadow: 0 0 28rpx rgba(255, 122, 0, 0.35), inset 0 0 26rpx rgba(255, 255, 255, 0.12);
}

.danger-btn {
  border: 1rpx solid rgba(255, 59, 48, 0.88);
  background: linear-gradient(180deg, rgba(255, 82, 70, 0.88), rgba(151, 22, 18, 0.94));
  box-shadow: 0 0 30rpx rgba(255, 59, 48, 0.32), inset 0 0 30rpx rgba(255, 255, 255, 0.08);
}

.ghost-btn {
  border: 1rpx solid rgba(255, 255, 255, 0.13);
  color: #d9dee8;
  background: rgba(16, 28, 42, 0.82);
}

.switch-row,
.control-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 74rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.switch-row:last-child,
.control-row:last-child {
  border-bottom: 0;
}

.slider-wrap {
  display: flex;
  align-items: center;
  flex: 1;
  margin-left: 26rpx;
}

.slider-wrap slider {
  flex: 1;
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  background: rgba(0, 0, 0, 0.52);
}

.bottom-sheet {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  bottom: 0;
  z-index: 60;
  max-height: 88vh;
  padding: 20rpx 20rpx calc(28rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 28rpx;
  background: linear-gradient(150deg, rgba(17, 31, 45, 0.98), rgba(5, 13, 23, 0.98));
  box-shadow: 0 -18rpx 64rpx rgba(0, 0, 0, 0.56);
}

.sheet-handle {
  width: 72rpx;
  height: 7rpx;
  margin: 0 auto 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.24);
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  min-width: 0;
}

.close-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 42rpx;
  width: 42rpx;
  height: 42rpx;
  min-width: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 9rpx;
  color: #ffffff;
  font-size: 30rpx;
  background: rgba(7, 17, 29, 0.82);
  box-shadow: 0 0 14rpx rgba(146, 187, 255, 0.1);
}

.close-btn .ui-icon {
  width: 20rpx;
  height: 20rpx;
}
